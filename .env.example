# --- Super admin (full payment-link / dashboard). Prefer this account in production. ---
SUPER_ADMIN_USERNAME=amituofo
SUPER_ADMIN_PASSWORD=amituofo123!

# --- Legacy operator login (still works if unset super admin credentials) ---
ADMIN_USERNAME=kuka
ADMIN_PASSWORD=change-this-password-too

# Used to sign the admin session cookie (min 16 characters; use a long random string)
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# --- Stripe (https://dashboard.stripe.com/apikeys) ---
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Required for embedded card fields (/pay and checkout). Add to Vercel → Project → Environment Variables.
#
# --- Pay links ---
# Signs short ?p=… links (fallback: ADMIN_SESSION_SECRET). Optional dedicated secret recommended in production:
# PAYMENT_LINK_SECRET=min-32-char-random-secret

# Public site URL — helps success/cancel redirects (set to your Vercel domain in production)
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app